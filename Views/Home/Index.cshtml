@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-home.css" asp-append-version="true" />
}

<div class="dashboard-page">
    <section class="dashboard-topbar">
        <div class="dashboard-topbar__content">
            <span class="dashboard-topbar__eyebrow">Dashboard</span>
            <h1 class="dashboard-topbar__title">Manage your store</h1>
        </div>

        <a asp-controller="AdminProducts"
           asp-action="Create"
           class="dashboard-topbar__button">
            <i class="bi bi-plus-lg"></i>
            Add product
        </a>
    </section>

    <section class="dashboard-sections">
        <div class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h2 class="dashboard-panel__title">Product management</h2>
                    <p class="dashboard-panel__subtitle">Products and listings</p>
                </div>
            </div>

            <div class="dashboard-actions">
                <a asp-controller="AdminProducts" asp-action="Index" class="dashboard-action dashboard-action--primary">
                    <span class="dashboard-action__icon">
                        <i class="bi bi-grid-3x3-gap"></i>
                    </span>

                    <span class="dashboard-action__body">
                        <span class="dashboard-action__title">My products</span>
                        <span class="dashboard-action__text">Edit, restock or remove listings</span>
                    </span>

                    <i class="bi bi-arrow-right dashboard-action__arrow"></i>
                </a>

                <a asp-controller="AdminProducts" asp-action="Create" class="dashboard-action">
                    <span class="dashboard-action__icon">
                        <i class="bi bi-box-seam"></i>
                    </span>

                    <span class="dashboard-action__body">
                        <span class="dashboard-action__title">Add product</span>
                        <span class="dashboard-action__text">Create a new product</span>
                    </span>

                    <i class="bi bi-arrow-right dashboard-action__arrow"></i>
                </a>
            </div>
        </div>

        <div class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h2 class="dashboard-panel__title">Catalog</h2>
                    <p class="dashboard-panel__subtitle">Structure and metadata</p>
                </div>
            </div>

            <div class="dashboard-actions">
                <a asp-controller="AdminBrands" asp-action="Index" class="dashboard-action">
                    <span class="dashboard-action__icon">
                        <i class="bi bi-award"></i>
                    </span>

                    <span class="dashboard-action__body">
                        <span class="dashboard-action__title">Brands</span>
                        <span class="dashboard-action__text">Manage product brands</span>
                    </span>

                    <i class="bi bi-arrow-right dashboard-action__arrow"></i>
                </a>

                <a asp-controller="Admin" asp-action="Category" class="dashboard-action">
                    <span class="dashboard-action__icon">
                        <i class="bi bi-folder-plus"></i>
                    </span>

                    <span class="dashboard-action__body">
                        <span class="dashboard-action__title">Categories</span>
                        <span class="dashboard-action__text">Manage category tree</span>
                    </span>

                    <i class="bi bi-arrow-right dashboard-action__arrow"></i>
                </a>
            </div>
        </div>

        <div class="dashboard-panel">
            <div class="dashboard-panel__header">
                <div>
                    <h2 class="dashboard-panel__title">Administration</h2>
                    <p class="dashboard-panel__subtitle">Internal tools and access</p>
                </div>
            </div>

            <div class="dashboard-actions">
                <a asp-controller="Admin" asp-action="SignUp" class="dashboard-action">
                    <span class="dashboard-action__icon">
                        <i class="bi bi-person-plus"></i>
                    </span>

                    <span class="dashboard-action__body">
                        <span class="dashboard-action__title">Add user</span>
                        <span class="dashboard-action__text">Register admin or moderator</span>
                    </span>

                    <i class="bi bi-arrow-right dashboard-action__arrow"></i>
                </a>

                <a asp-controller="Admin" asp-action="Action" class="dashboard-action">
                    <span class="dashboard-action__icon">
                        <i class="bi bi-tag"></i>
                    </span>

                    <span class="dashboard-action__body">
                        <span class="dashboard-action__title">Actions</span>
                        <span class="dashboard-action__text">Create promotional discounts</span>
                    </span>

                    <i class="bi bi-arrow-right dashboard-action__arrow"></i>
                </a>
            </div>
        </div>
    </section>
</div>