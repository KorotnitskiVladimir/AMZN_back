@using AMZN.Data.Entities
@model List<Brand>

@{
    ViewData["Title"] = "Brands";

    string? errorMessage = TempData["Error"] as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/management-pages.css" asp-append-version="true" />
}

<div class="management-page">
    <div class="management-page__header">
        <div>
            <h1 class="management-page__title">Brands</h1>
            <p class="management-page__subtitle">
                Manage available brands used in product forms and filters.
            </p>
        </div>

        <a asp-action="Create" class="action-button action-button--primary">Create brand</a>
    </div>


    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert-box alert-box--danger" role="alert">@errorMessage</div>
    }

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <h2 class="empty-state__title">No brands yet</h2>
            <p class="empty-state__text">
                Create the first brand to start assigning brands to products.
            </p>

            <div class="action-bar action-bar--center">
                <a asp-action="Create" class="action-button action-button--primary">Create brand</a>
            </div>
        </div>
    }
    else
    {
        <div class="table-card">
            <div class="table-wrap">
                <table class="management-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th style="width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var brand in Model)
                        {
                            <tr>
                                <td>@brand.Name</td>
                                <td>
                                    <div class="inline-actions">
                                        <button type="button"
                                                class="action-button action-button--danger action-button--small"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteConfirmModal"
                                                data-delete-url="@Url.Action("Delete", "AdminBrands", new { id = brand.Id })"
                                                data-entity-name="@brand.Name"
                                                data-entity-label="brand">
                                            Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<partial name="_DeleteConfirmModal" />

@section Scripts {
    <script src="~/js/product-management.js" asp-append-version="true"></script>
}