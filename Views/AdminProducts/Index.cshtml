@using AMZN.Models.Product
@model MyProductsListViewModel

@{
    ViewData["Title"] = "My products";

    string? successMessage = TempData["Success"] as string;
    string? errorMessage = TempData["Error"] as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/management-pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/product-management.css" asp-append-version="true" />
}


<div class="management-page">
    <div class="management-page__header">
        <div>
            <h1 class="management-page__title">My products</h1>
            <p class="management-page__subtitle">
                Manage your products, update media and keep stock information up to date.
            </p>
        </div>

        <a asp-action="Create" class="action-button action-button--primary">Add product</a>
    </div>

    <partial name="_SuccessToast" model="successMessage" />

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert-box alert-box--danger" role="alert">@errorMessage</div>
    }

    @if (Model.Products.Count == 0)
    {
        <div class="empty-state">
            <h2 class="empty-state__title">No products yet</h2>
            <p class="empty-state__text">
                Start by creating your first product.
            </p>

            <div class="action-bar action-bar--center">
                <a asp-action="Create" class="action-button action-button--primary">Create product</a>
            </div>
        </div>
    }
    else
    {
        <div class="table-card">
            <div class="table-wrap">
                <table class="management-table">
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Title</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Created</th>
                            <th style="width: 190px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.Products)
                        {
                            <tr>
                                <td>
                                    <img src="@product.PrimaryImageUrl"
                                         alt="@product.Title"
                                         class="products-thumbnail" />
                                </td>
                                <td class="products-title-cell">@product.Title</td>
                                <td>@product.CurrentPrice.ToString("F2")</td>
                                <td>@product.StockQuantity</td>
                                <td>@product.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <div class="inline-actions">
                                        <a asp-action="Edit"
                                           asp-route-id="@product.Id"
                                           class="action-button action-button--warning action-button--small">
                                            Edit
                                        </a>

                                        <button type="button"
                                                class="action-button action-button--danger action-button--small"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteConfirmModal"
                                                data-delete-url="@Url.Action("Delete", "AdminProducts", new { id = product.Id })"
                                                data-entity-name="@product.Title"
                                                data-entity-label="product">
                                            Delete
                                        </button>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<partial name="_DeleteConfirmModal" />


@section Scripts {
    <script src="~/js/product-management.js" asp-append-version="true"></script>
}
