@model AMZN.Models.Action.ActionViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Add action";

    bool isAuthorized = Context.Items.ContainsKey("auth");
    string? role = Context.User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;
}

@section Styles {
    <link rel="stylesheet" href="~/css/management-pages.css" asp-append-version="true" />
}

<div class="management-page">

    <div class="management-page__header">
        <div>
            <h1 class="management-page__title">Add action</h1>
            <p class="management-page__subtitle">
                Create a promotional action for a product or category.
            </p>
        </div>
    </div>

    @if (!isAuthorized)
    {
        <div class="alert-box alert-box--danger" role="alert">
            You are not authorized to view this page.
        </div>
    }
    else if (role != "Admin")
    {
        <div class="alert-box alert-box--danger" role="alert">
            Admin role is required to manage actions.
        </div>
    }
    else
    {
        <div id="action-feedback"></div>

        <form id="add-action-form">

            <section class="panel panel--full">

                <div class="form-grid form-grid--2">
                    <div class="field-group">
                        <label class="form-label" for="action-name">Name</label>
                        <input id="action-name" name="action-name" class="form-control" />
                    </div>
                    <div class="field-group">
                        <label class="form-label" for="apply-to">Apply to</label>
                        <select id="apply-to" name="apply-to" class="form-select">
                            <option value="product">Single product</option>
                            <option value="category">Whole category</option>
                        </select>
                    </div>
                </div>

                <div class="form-grid form-grid--2 mt-3">
                    <div class="field-group">
                        <label class="form-label" for="product-title">Product / Category name</label>
                        <input id="product-title" name="product-title" class="form-control" />
                    </div>
                    <div class="field-group">
                        <label class="form-label" for="action-amount">Discount (%)</label>
                        <input id="action-amount" name="action-amount"
                               type="number" min="1" max="99"
                               class="form-control" />
                    </div>
                </div>

                <div class="form-grid form-grid--2 mt-3">
                    <div class="field-group">
                        <label class="form-label" for="action-start-date">Start date</label>
                        <input id="action-start-date" name="action-start-date"
                               type="date" class="form-control" />
                    </div>
                    <div class="field-group">
                        <label class="form-label" for="action-end-date">End date</label>
                        <input id="action-end-date" name="action-end-date"
                               type="date" class="form-control" />
                    </div>
                </div>

                <div class="form-grid mt-3">
                    <div class="field-group">
                        <label class="form-label" for="action-description">Description</label>
                        <textarea id="action-description" name="action-description"
                              class="form-control"></textarea>
                    </div>
                </div>

            </section>

            <div class="action-bar">
                <button type="submit" class="action-button action-button--primary">
                    Add action
                </button>
            </div>

        </form>
    }

</div>