@model string?

@if (!string.IsNullOrWhiteSpace(Model))
{
    <div class="toast-container position-fixed top-0 start-50 translate-middle-x p-3 success-toast-container">
        <div class="toast align-items-center text-bg-success border-0 js-success-toast"
             role="alert"
             aria-live="assertive"
             aria-atomic="true"
             data-bs-autohide="true"
             data-bs-delay="5000">
            <div class="d-flex">
                <div class="toast-body">
                    @Model
                </div>

                <button type="button"
                        class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"
                        aria-label="Close"></button>
            </div>
        </div>
    </div>
}
